MERCADOPAGO_CLIENT_ID=app_id_da_aplicacao
MERCADOPAGO_CLIENT_SECRET=client_secret_da_aplicacao
MERCADOPAGO_REDIRECT_URI=https://SEU-PROJETO.supabase.co/functions/v1/mercadopago-oauth-callback
MERCADOPAGO_OAUTH_STATE_SECRET=gere_uma_string_longa_aleatoria
MERCADOPAGO_ALLOWED_RETURN_ORIGINS=http://localhost:5176,http://localhost:5174,https://seu-dominio.com
MERCADOPAGO_DEFAULT_RETURN_URL=http://localhost:5176/perfil
MERCADOPAGO_WEBHOOK_URL=https://SEU-PROJETO.supabase.co/functions/v1/mercadopago-webhook
MERCADOPAGO_WEBHOOK_SECRET=secret_da_tela_de_webhooks
PUBLIC_SITE_URL=http://localhost:5175

# Ingressos de eventos vendidos pela PraiaGo.
# O checkout usa o MERCADOPAGO_ACCESS_TOKEN da empresa e a funcao aplica a margem
# de 25% no banco, nunca no frontend.
EVENT_TICKET_BOT_SECRET=gere_uma_string_longa_para_o_bot_aprovar_reembolsos
EVENT_TICKET_ADMIN_EMAIL=admin@seudominio.com
ADMIN_EMAIL=admin@seudominio.com
EMAIL_FROM=PraiaGo <noreply@seudominio.com>
RESEND_API_KEY=
MAILGUN_API_KEY=
MAILGUN_DOMAIN=
ARTICKET_DETAIL_MAX=20

# SMTP do Supabase Auth e configurado no Dashboard do Supabase.
# Para e-mails transacionais das Edge Functions, use RESEND_API_KEY ou Mailgun acima.
SMTP_HOST=smtp.seudominio.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=PraiaGo <noreply@seudominio.com>

# IA do suporte: mantenha estes valores apenas em Supabase Edge Function Secrets.
AI_CHAT_API_KEY=chave_secreta_do_provedor_de_ia
AI_CHAT_BASE_URL=https://api.openai.com/v1
AI_CHAT_MODEL=gpt-4o-mini
