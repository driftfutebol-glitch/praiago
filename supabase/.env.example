# ── Gateway de pagamento: PAGAR.ME ──────────────────────────────────────────
# A conta e do DONO do PraiaGo (CNPJ dele) — o dinheiro das vendas cai direto
# pra ele. Estas chaves ficam SO em Supabase Edge Function Secrets, nunca no app.
# Dica: o modo teste da Pagar.me libera as chaves na hora, antes do KYC aprovar.
PAGARME_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxx
PAGARME_PUBLIC_KEY=pk_test_xxxxxxxxxxxxxxxx
PAGARME_WEBHOOK_SECRET=secret_configurado_na_tela_de_webhooks_da_pagarme
PAGARME_WEBHOOK_URL=https://SEU-PROJETO.supabase.co/functions/v1/pagarme-webhook

PUBLIC_SITE_URL=http://localhost:5175

# Ingressos de eventos vendidos pela PraiaGo.
# O checkout cobra pela conta da empresa e a funcao aplica a margem de 25%
# no banco, nunca no frontend.
EVENT_TICKET_BOT_SECRET=gere_uma_string_longa_para_o_bot_aprovar_reembolsos
EVENT_TICKET_ADMIN_EMAIL=admin@seudominio.com
ADMIN_EMAIL=admin@seudominio.com
EMAIL_FROM=PraiaGo <noreply@seudominio.com>
RESEND_API_KEY=
MAILGUN_API_KEY=
MAILGUN_DOMAIN=
ARTICKET_DETAIL_MAX=20

# SMTP do Supabase Auth e configurado no Dashboard do Supabase.
# Para e-mails transacionais das Edge Functions, use RESEND_API_KEY ou Mailgun acima.
SMTP_HOST=smtp.seudominio.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=PraiaGo <noreply@seudominio.com>

# IA do suporte: mantenha estes valores apenas em Supabase Edge Function Secrets.
AI_CHAT_API_KEY=chave_secreta_do_provedor_de_ia
AI_CHAT_BASE_URL=https://api.openai.com/v1
AI_CHAT_MODEL=gpt-4o-mini
